  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="CreditRiskDB">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=.;Initial Catalog=CreditRiskDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>a521ddc1-82a2-4e62-8f37-ad8b8f91488f</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsCustomerRisk">
      <Query>
        <DataSourceName>CreditRiskDB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@RiskTierCode">
            <Value>=Parameters!RiskTierCode.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    c.CustomerID,
    c.FullName,
    c.EmploymentStatus,
    rs.NumericScore,
    rt.TierLabel,
    rs.ScoreDate,
    a.AccountType,
    a.Balance,
    a.CreditLimit
FROM Customer c
JOIN RiskScore rs ON c.CustomerID = rs.CustomerID
JOIN RiskTier rt ON rs.RiskTierCode = rt.RiskTierCode
JOIN Account a ON c.CustomerID = a.CustomerID
WHERE rt.RiskTierCode = @RiskTierCode
   OR @RiskTierCode = 'ALL'
ORDER BY rs.NumericScore DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerID">
          <DataField>CustomerID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FullName">
          <DataField>FullName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EmploymentStatus">
          <DataField>EmploymentStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NumericScore">
          <DataField>NumericScore</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TierLabel">
          <DataField>TierLabel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ScoreDate">
          <DataField>ScoreDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="AccountType">
          <DataField>AccountType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Balance">
          <DataField>Balance</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CreditLimit">
          <DataField>CreditLimit</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>

  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="CreditRiskDB">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=.;Initial Catalog=CreditRiskDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>cfb89fd9-0c81-459d-8983-776c9f368904</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsRiskMatrix">
      <Query>
        <DataSourceName>CreditRiskDB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ScoreYear">
            <Value>=Parameters!ScoreYear.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    rt.TierLabel,
    rt.RiskTierCode,
    COUNT(DISTINCT c.CustomerID) AS CustomerCount,
    AVG(rs.NumericScore) AS AvgScore,
    SUM(a.Balance) AS TotalBalance,
    SUM(a.CreditLimit) AS TotalCreditLimit,
    AVG(cu.UtilizationRate) AS AvgUtilization
FROM RiskTier rt
JOIN RiskScore rs ON rt.RiskTierCode = rs.RiskTierCode
JOIN Customer c ON rs.CustomerID = c.CustomerID
JOIN Account a ON c.CustomerID = a.CustomerID
JOIN CreditUtilization cu ON a.AccountID = cu.AccountID
WHERE YEAR(rs.ScoreDate) = @ScoreYear
   OR @ScoreYear = 0
GROUP BY rt.TierLabel, rt.RiskTierCode
ORDER BY AVG(rs.NumericScore) DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="TierLabel">
          <DataField>TierLabel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RiskTierCode">
          <DataField>RiskTierCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerCount">
          <DataField>CustomerCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="AvgScore">
          <DataField>AvgScore</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TotalBalance">
          <DataField>TotalBalance</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="TotalCreditLimit">
          <DataField>TotalCreditLimit</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="AvgUtilization">
          <DataField>AvgUtilization</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
